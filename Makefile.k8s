.PHONY: setup namespace apply-pvc deploy-training deploy-eval deploy-all run-training run-eval run-all logs-training logs-eval status describe-training describe-eval clean clean-all

TRAINING_JOB_NAME ?= training
EVAL_JOB_NAME ?= evaluation

setup: ## Verify kubectl/cluster and create namespace
	@echo "[setup] Checking kubectl installation"
	@command -v kubectl >/dev/null 2>&1 || { echo "Error: kubectl is not installed or not in PATH"; exit 1; }
	@echo "[setup] Checking Kubernetes cluster connectivity"
	@kubectl cluster-info >/dev/null
	@echo "[setup] Ensuring namespace $(NAMESPACE) exists"
	@$(MAKE) namespace
	@echo "[setup] Kubernetes environment ready"

namespace: ## Create namespace if it does not exist
	@echo "[namespace] Ensuring namespace $(NAMESPACE) exists"
	@kubectl get namespace $(NAMESPACE) >/dev/null 2>&1 || kubectl create namespace $(NAMESPACE)

apply-pvc: ## Apply persistent volume claim
	@echo "[apply-pvc] Applying PVC from $(K8S_DIR)/pvc.yaml"
	@kubectl apply -n $(NAMESPACE) -f $(K8S_DIR)/pvc.yaml

deploy-training: ## Deploy training job manifest
	@echo "[deploy-training] Applying $(K8S_DIR)/training-job.yaml"
	@kubectl apply -n $(NAMESPACE) -f $(K8S_DIR)/training-job.yaml

deploy-eval: ## Deploy evaluation job manifest
	@echo "[deploy-eval] Applying $(K8S_DIR)/evaluation-job.yaml"
	@kubectl apply -n $(NAMESPACE) -f $(K8S_DIR)/evaluation-job.yaml

deploy-all: apply-pvc deploy-training deploy-eval ## Deploy PVC, training, and evaluation manifests
	@echo "[deploy-all] Applied all Kubernetes resources"

run-training: ## Recreate and run training job
	@echo "[run-training] Recreating job $(TRAINING_JOB_NAME)"
	@kubectl delete job $(TRAINING_JOB_NAME) -n $(NAMESPACE) --ignore-not-found
	@kubectl apply -n $(NAMESPACE) -f $(K8S_DIR)/training-job.yaml

run-eval: ## Recreate and run evaluation job
	@echo "[run-eval] Recreating job $(EVAL_JOB_NAME)"
	@kubectl delete job $(EVAL_JOB_NAME) -n $(NAMESPACE) --ignore-not-found
	@kubectl apply -n $(NAMESPACE) -f $(K8S_DIR)/evaluation-job.yaml

run-all: run-training run-eval ## Run training then evaluation jobs
	@echo "[run-all] Triggered training and evaluation jobs"

logs-training: ## Stream logs for training job pod
	@echo "[logs-training] Fetching pod for job $(TRAINING_JOB_NAME)"
	@kubectl logs -n $(NAMESPACE) -f $$(kubectl get pods -n $(NAMESPACE) -l job-name=$(TRAINING_JOB_NAME) -o jsonpath='{.items[0].metadata.name}')

logs-eval: ## Stream logs for evaluation job pod
	@echo "[logs-eval] Fetching pod for job $(EVAL_JOB_NAME)"
	@kubectl logs -n $(NAMESPACE) -f $$(kubectl get pods -n $(NAMESPACE) -l job-name=$(EVAL_JOB_NAME) -o jsonpath='{.items[0].metadata.name}')

status: ## Show pod and job status
	@echo "[status] Pods in namespace $(NAMESPACE)"
	@kubectl get pods -n $(NAMESPACE)
	@echo "[status] Jobs in namespace $(NAMESPACE)"
	@kubectl get jobs -n $(NAMESPACE)

describe-training: ## Describe training job
	@echo "[describe-training] Describing job $(TRAINING_JOB_NAME)"
	@kubectl describe job $(TRAINING_JOB_NAME) -n $(NAMESPACE)

describe-eval: ## Describe evaluation job
	@echo "[describe-eval] Describing job $(EVAL_JOB_NAME)"
	@kubectl describe job $(EVAL_JOB_NAME) -n $(NAMESPACE)

clean: ## Delete jobs and pods in namespace
	@echo "[clean] Deleting jobs"
	@kubectl delete job $(TRAINING_JOB_NAME) -n $(NAMESPACE) --ignore-not-found
	@kubectl delete job $(EVAL_JOB_NAME) -n $(NAMESPACE) --ignore-not-found
	@echo "[clean] Deleting pods for jobs"
	@kubectl delete pods -n $(NAMESPACE) -l job-name=$(TRAINING_JOB_NAME) --ignore-not-found
	@kubectl delete pods -n $(NAMESPACE) -l job-name=$(EVAL_JOB_NAME) --ignore-not-found

clean-all: clean ## Delete jobs, pods, and PVC
	@echo "[clean-all] Deleting PVC from $(K8S_DIR)/pvc.yaml"
	@kubectl delete -n $(NAMESPACE) -f $(K8S_DIR)/pvc.yaml --ignore-not-found
